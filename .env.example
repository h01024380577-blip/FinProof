# FinProof Agent local backend
# For local Docker Postgres, DATABASE_URL is enough.
# For Supabase production, set DATABASE_URL to the transaction pooler URL on port 6543
# and DIRECT_URL to the session/direct URL on port 5432 for Prisma migrations and seed.
# Supabase example:
# DATABASE_URL="postgresql://prisma.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://prisma.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres"
DATABASE_URL="postgresql://finproof:finproof@localhost:5432/finproof_agent?schema=public"
DIRECT_URL=""

# mock keeps the current demo path. Set prisma to use Postgres.
FINPROOF_REVIEW_STORE="mock"
# Keep production and local real-flow screens empty until operators upload actual packages.
FINPROOF_ENABLE_SAMPLE_DATA="false"

# demo uses local headers. Set jwt for production bearer sessions.
FINPROOF_AUTH_MODE="demo"
FINPROOF_AUTH_JWKS_URL=""
FINPROOF_AUTH_JWT_ISSUER=""
FINPROOF_AUTH_JWT_AUDIENCE="finproof-agent"
FINPROOF_AUTH_JWT_SECRET=""

# Header fallback context for local demo route calls.
FINPROOF_DEFAULT_TENANT_ID="tenant-demo"
FINPROOF_DEFAULT_REVIEWER_USER_ID="user-reviewer-demo"
FINPROOF_DEFAULT_REQUESTER_USER_ID="user-requester-demo"

# deterministic keeps the current local demo path. Set router in prod for feature-based routing.
FINPROOF_MODEL_PROVIDER="deterministic"
OPENAI_API_KEY=""
GEMINI_API_KEY=""
FINPROOF_MODEL_DEFAULT_TEXT="gpt-5-mini"
FINPROOF_MODEL_ESCALATION_TEXT="gpt-5.4"
FINPROOF_MODEL_HIGHEST_PRECISION_TEXT="gpt-5.5"
FINPROOF_MODEL_MULTIMODAL="gemini-2.5-flash"
FINPROOF_MODEL_MULTIMODAL_ESCALATION="gemini-2.5-pro"
FINPROOF_EMBEDDING_PROVIDER="openai"
FINPROOF_EMBEDDING_ENDPOINT=""
FINPROOF_EMBEDDING_MODEL="text-embedding-3-small"
FINPROOF_EMBEDDING_ESCALATION_MODEL="text-embedding-3-large"

# OCR/RAG quality knobs. Default "deterministic" => OFF (legacy local extraction only).
#
# FINPROOF_OCR_PROVIDER options:
#   deterministic  : OFF — legacy local extraction only (default).
#   hybrid         : content-based routing (recommended). Digital PDFs/DOCX -> Python
#                    service (pdfplumber/python-docx), images & scanned PDFs -> OpenAI
#                    vision, text -> local. Needs FINPROOF_OCR_ENDPOINT + OPENAI_API_KEY.
#   http           : route image/scanned files through the Python OCR microservice only
#                    (ocr-service/, multipart /extract). "python_service" is a kept alias.
#   openai|gemini  : send images/scanned files to a single vision LLM.
#   http_json      : legacy speculative JSON-batch API (createHttpOcrProvider).
# Digital text files always stay on the local extractor; any engine failure falls back.
FINPROOF_OCR_PROVIDER="deterministic"
# Base URL of the OCR microservice (required when FINPROOF_OCR_PROVIDER="http" or "hybrid").
FINPROOF_OCR_ENDPOINT=""
# Per-call timeout for the OCR microservice in ms (optional, default 30000).
FINPROOF_OCR_TIMEOUT_MS="30000"
FINPROOF_OCR_MODEL="gemini-2.5-flash-lite"
FINPROOF_OCR_MAX_INLINE_BYTES="20971520"
# Optional Poppler paths. Leave blank to search PATH and common Linux/Homebrew locations.
FINPROOF_PDFTOTEXT_PATH=""
FINPROOF_PDFTOPPM_PATH=""
FINPROOF_OCR_PDF_RENDER_MAX_PAGES="3"
FINPROOF_RAG_PROVIDER="deterministic"
FINPROOF_RAG_TOP_K="4"
FINPROOF_RAG_MIN_SCORE="0.5"
# Lower retrieval floor for knowledge-corpus (law/internal_policy) evidence. Korean
# ad-copy↔regulation cosine tops out ~0.6, so an on-point checklist can sit ~0.46 and
# would be dropped by FINPROOF_RAG_MIN_SCORE before reranking; keep this below it.
FINPROOF_RAG_KNOWLEDGE_MIN_SCORE="0.4"
FINPROOF_RAG_MAX_CONTEXT_CHARS="6000"
FINPROOF_RERANK_PROVIDER="cohere"
COHERE_API_KEY=""
FINPROOF_RERANK_MODEL="rerank-v3.5"
FINPROOF_RERANK_TOP_K="4"
FINPROOF_ANALYSIS_EXECUTION_MODE="queued"
FINPROOF_WORKER_TENANT_ID=""
FINPROOF_ANALYSIS_WORKER_ID="finproof-analysis-worker"

# deterministic allows local uploads. Set http to block unsafe files through a scanner gateway.
FINPROOF_UPLOAD_SCAN_PROVIDER="deterministic"
FINPROOF_UPLOAD_SCAN_ENDPOINT=""
FINPROOF_UPLOAD_SCAN_API_KEY=""

# local-metadata stores upload bytes on local disk for OCR/RAG dev flows.
# Keep S3 blank locally; the EC2 runtime env template enables S3 for production.
FINPROOF_STORAGE_ADAPTER="local-metadata"
FINPROOF_LOCAL_UPLOAD_DIR="/tmp/finproof-uploads"
FINPROOF_S3_BUCKET=""
AWS_REGION=""
