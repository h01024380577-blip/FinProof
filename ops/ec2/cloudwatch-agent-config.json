{
  "agent": {
    "run_as_user": "root",
    "region": "ap-northeast-2"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/finproof/app.log",
            "log_group_name": "/finproof/app",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 30,
            "timezone": "UTC"
          },
          {
            "file_path": "/var/log/finproof/analysis-worker.log",
            "log_group_name": "/finproof/analysis-worker",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 30,
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
